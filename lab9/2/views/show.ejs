<!DOCTYPE html>
<html lang="en">

<head>
    <title>Questions</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4 mb-5">
    <h2>Questions</h2>
    <form action="/submit" method="POST" class="mt-4">
        <% questions.forEach((q, index) => { %>
            <div class="mb-4">
                <h5>
                    <%= index + 1 %>.
                        <%= q.Stem %>
                </h5>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="q<%= q.QID %>" value="A" required>
                    <label class="form-check-label"><%= q.Alt_A %></label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="q<%= q.QID %>" value="B">
                    <label class="form-check-label"><%= q.Alt_B %></label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="q<%= q.QID %>" value="C">
                    <label class="form-check-label"><%= q.Alt_C %></label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="q<%= q.QID %>" value="D">
                    <label class="form-check-label"><%= q.Alt_D %></label>
                </div>
            </div>
            <% }); %>

                <button type="submit" class="btn btn-primary btn-lg">
            Submit Answers
        </button>
    </form>
</body>

</html>