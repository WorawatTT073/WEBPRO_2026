<style>
table {
    border-collapse: collapse;
    width: 100%;
}

th {
    background-color: #1976d2;
    color: white;
    padding: 10px;
}

td {
    border: 1px solid #ccc;
    padding: 8px;
    text-align: center;
}

tr:nth-child(even) {
    background-color: #f2f2f2;
}

h1{
    text-align: center;
}
</style>

<h1>Book Store</h1>

<table border="1" style="border-collapse: collapse; width:100%;">
    <tr>
        <th>ID</th>
        <th>Book Name</th>
        <th>Description</th>
        <th>Price</th>
        <th>Amount</th>
    </tr>

    <% books.forEach(function(book) { %>
        <tr>
            <td><%= book.id %></td>
            <td><%= book.name %></td>
            <td><%= book.description %></td>
            <td><%= book.price %></td>
            <td><%= book.amount %></td>
        </tr>
    <% }); %>
</table>